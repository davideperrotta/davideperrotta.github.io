---
import astroLogo from '../assets/astro.svg';

const year = new Date().getFullYear();
const {
	title =
		'Davide Perrotta · Web developer, software developer and software architect in Milano and Catanzaro (Italy)',
	description =
		"Portfolio and resume of Davide Perrotta, web developer, software developer and software architect based between Milano and Catanzaro (Italy). Sviluppatore web, sviluppatore software e architetto software che progetta e realizza applicazioni web moderne e performanti.",
	noindex = false,
} = Astro.props;

const canonicalUrl = new URL(
	Astro.url.pathname || '/',
	Astro.site ?? 'https://davideperrotta.github.io/',
).toString();

const personJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	'@id': `${canonicalUrl}#person`,
	name: 'Davide Perrotta',
	alternateName: 'Davide Perrotta · Sviluppatore web e software',
	jobTitle:
		'Web Developer, Full-Stack Developer, Mobile Developer, Software Developer, Software Architect',
	url: canonicalUrl,
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': canonicalUrl,
	},
	sameAs: [
		'https://www.davideperrotta.it',
		'https://github.com/davideperrotta',
		'https://www.linkedin.com/in/davideperrotta/',
	],
	address: [
		{
			'@type': 'PostalAddress',
			addressLocality: 'Milano',
			addressCountry: 'IT',
		},
		{
			'@type': 'PostalAddress',
			addressLocality: 'Catanzaro',
			addressCountry: 'IT',
		},
	],
	nationality: {
		'@type': 'Country',
		name: 'Italy',
	},
	homeLocation: [
		{
			'@type': 'City',
			name: 'Milano',
			addressCountry: 'IT',
		},
		{
			'@type': 'City',
			name: 'Catanzaro',
			addressCountry: 'IT',
		},
	],
	knowsLanguage: ['it-IT', 'en'],
	hasOccupation: [
		{
			'@type': 'Occupation',
			name: 'Web Developer',
			occupationalCategory: 'Software and Applications Developers',
			description: 'Sviluppatore web e frontend',
		},
		{
			'@type': 'Occupation',
			name: 'Software Developer',
			description: 'Sviluppatore software e ingegnere IT',
		},
		{
			'@type': 'Occupation',
			name: 'Full-Stack Developer',
			description: 'Sviluppatore full-stack web e mobile',
		},
		{
			'@type': 'Occupation',
			name: 'Mobile Developer',
			description: 'Sviluppatore mobile e app',
		},
		{
			'@type': 'Occupation',
			name: 'Software Architect',
			description: 'Architetto software e ingegnere IT',
		},
	],
	knowsAbout: [
		'web development',
		'software development',
		'software architecture',
		'frontend engineering',
		'backend development',
		'full-stack development',
		'mobile app development',
		'web developer',
		'software developer',
		'full-stack developer',
		'mobile developer',
		'software architect',
		'IT engineer',
		'sviluppo web',
		'sviluppo software',
		'architettura software',
		'ingegneria del software',
		'sviluppatore web',
		'sviluppatore full-stack',
		'sviluppatore mobile',
		'ingegnere informatico',
		'ingegnere IT',
		'web developer in Milan',
		'web developer in Catanzaro',
		'sviluppatore web Milano',
		'sviluppatore web Catanzaro',
	],
};

const websiteJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	'@id': `${canonicalUrl}#website`,
	url: canonicalUrl,
	name: 'Davide Perrotta · Web & Software Developer',
	inLanguage: ['it-IT', 'en'],
	description,
	publisher: {
		'@id': `${canonicalUrl}#person`,
	},
};

const webPageJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebPage',
	'@id': canonicalUrl,
	url: canonicalUrl,
	name: title,
	inLanguage: ['it-IT', 'en'],
	description,
	isPartOf: {
		'@id': `${canonicalUrl}#website`,
	},
	about: [
		'web developer',
		'software developer',
		'full-stack developer',
		'mobile developer',
		'software architect',
		'IT engineer',
		'sviluppatore web',
		'sviluppatore full-stack',
		'sviluppatore mobile',
		'ingegnere informatico',
		'ingegnere IT',
		'web developer in Milan',
		'web developer in Catanzaro',
		'sviluppatore web Milano',
		'sviluppatore web Catanzaro',
	],
};
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="google-site-verification" content="0voRi7hp4tjcX4patEEtsjdL-KE1rfIZSIxh2e5p9w4" />
		<meta name="google-site-verification" content="1dbQn6wN29Sww3Uh8KSum2nP0NXVjsy72ZMD70VkKss" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="favicon.svg" />
		<link rel="icon" type="image/x-icon" href="favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="Davide Perrotta" />
		<meta property="og:locale" content="en_US" />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}
		<script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
		<script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
		<script type="application/ld+json" set:html={JSON.stringify(webPageJsonLd)} />
	</head>
	<body>
		<slot />
		<footer class="site-footer">
			<span>{year} · Davide Perrotta · Built with Astro, Keystatic, A.I.</span>
			<img
				class="site-footer__logo"
				src={astroLogo.src}
				alt="Astro"
				height="20"
				loading="lazy"
			/>
		</footer>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}

	body {
		min-height: 100vh;
		font-family: system-ui, -apple-system, BlinkMacSystemFont, 'SF Pro Text',
			'Helvetica Neue', Arial, sans-serif;
		background:
			radial-gradient(circle at top left, #1f2937 0, transparent 55%),
			radial-gradient(circle at bottom right, #0f172a 0, transparent 55%),
			radial-gradient(circle at top right, #4f46e5 0, transparent 50%);
		background-color: #020617;
		background-repeat: no-repeat;
		background-attachment: fixed;
		color: #e5e7eb;
		padding: 2.5rem 1rem 2rem;
		box-sizing: border-box;
	}

	.site-footer {
		padding: 1.5rem;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.6rem;
		font-size: 0.8rem;
		color: var(--text-muted);
		opacity: 0.9;
		text-align: center;
	}

	.site-footer__logo {
		background-color: #ffffff;
		border-radius: 999px;
		padding: 3px;
	}

	:root {
		--accent: #4f46e5;
		--accent-soft: #a5b4fc;
		--accent-strong: #818cf8;
		--text-muted: #9ca3af;
	}
</style>
