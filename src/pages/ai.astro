---
import Layout from '../layouts/Layout.astro';
import { AiChat } from '../components/AiChat';

const title = 'AI · Chat con Cloudflare Workers AI';
const description =
	"Pagina AI del sito di Davide Perrotta, con una chat alimentata da Cloudflare Workers AI per fare domande e ricevere risposte.";
---

<Layout {title} {description}>
	<main class="ai-page">
		<section class="ai-card">
			<h1 class="ai-title">AI Chat</h1>
			<p class="ai-subtitle">
				Fai una domanda e ricevi la risposta dal tuo worker Cloudflare AI.
			</p>
			<AiChat client:load />
		</section>
	</main>
</Layout>

<style>
	.ai-page {
		max-width: 1160px;
		margin: 0 auto;
		min-height: 70vh;
		display: flex;
		align-items: stretch;
		justify-content: center;
	}

	.ai-card {
		flex: 1;
		background: rgba(15, 23, 42, 0.85);
		border-radius: 1.25rem;
		padding: 1.5rem;
		border: 1px solid rgba(148, 163, 184, 0.3);
		box-shadow: 0 18px 40px rgba(15, 23, 42, 0.55);
		display: flex;
		flex-direction: column;
	}

	.ai-title {
		margin-top: 0;
		margin-bottom: 0.4rem;
		font-size: 1.5rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--accent-soft);
	}

	.ai-subtitle {
		margin-top: 0;
		margin-bottom: 1rem;
		font-size: 0.95rem;
		color: var(--text-muted);
	}

	.ai-chat {
		flex: 1;
		min-height: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.ai-chat__messages {
		flex: 1;
		min-height: 0;
		padding: 0.75rem;
		border-radius: 0.9rem;
		background: radial-gradient(circle at top left, #020617 0, #020617 55%),
			linear-gradient(to bottom right, rgba(15, 23, 42, 0.9), rgba(17, 24, 39, 0.95));
		border: 1px solid rgba(55, 65, 81, 0.9);
		overflow-y: auto;
		font-size: 0.95rem;
	}

	.ai-chat__placeholder {
		margin: 0;
		color: var(--text-muted);
	}

	.ai-chat__message {
		margin-bottom: 0.8rem;
		max-width: 90%;
	}

	.ai-chat__message-role {
		display: block;
		margin-bottom: 0.2rem;
		font-size: 0.7rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--accent-soft);
	}

	.ai-chat__message-text {
		margin: 0;
		padding: 0.55rem 0.7rem;
		border-radius: 0.7rem;
		line-height: 1.5;
	}

	.ai-chat__message--user {
		margin-left: auto;
		text-align: right;
	}

	.ai-chat__message--user .ai-chat__message-text {
		background: linear-gradient(135deg, var(--accent), var(--accent-strong));
		color: #e5e7eb;
	}

	.ai-chat__message--assistant .ai-chat__message-text {
		background: rgba(15, 23, 42, 0.95);
		border: 1px solid rgba(148, 163, 184, 0.6);
	}

	.ai-chat__message--pending .ai-chat__message-text {
		opacity: 0.7;
		font-style: italic;
	}

	.ai-chat__error {
		margin: 0.25rem 0 0;
		color: #fecaca;
		font-size: 0.8rem;
	}

	.ai-chat__form {
		display: flex;
		gap: 0.6rem;
		margin-top: 0.5rem;
	}

	.ai-chat__input {
		flex: 1;
		border-radius: 999px;
		border: 1px solid rgba(75, 85, 99, 0.9);
		background: rgba(15, 23, 42, 0.9);
		color: #e5e7eb;
		padding: 0.6rem 0.9rem;
		font-size: 0.95rem;
		outline: none;
	}

	.ai-chat__input:focus {
		border-color: var(--accent-soft);
		box-shadow: 0 0 0 1px rgba(129, 140, 248, 0.6);
	}

	.ai-chat__button {
		border-radius: 999px;
		border: none;
		background: linear-gradient(135deg, var(--accent), var(--accent-strong));
		color: #e5e7eb;
		padding: 0.55rem 1.1rem;
		font-size: 0.9rem;
		font-weight: 500;
		cursor: pointer;
		transition: transform 0.08s ease, box-shadow 0.08s ease,
			background 0.12s ease;
	}

	.ai-chat__button:hover:not(:disabled) {
		transform: translateY(-1px);
		box-shadow: 0 8px 18px rgba(55, 65, 81, 0.7);
	}

	.ai-chat__button:disabled {
		opacity: 0.6;
		cursor: default;
	}

	@media (max-width: 640px) {
		.ai-page {
			padding-inline: 0.25rem;
		}

		.ai-card {
			padding: 1.2rem 1rem;
		}

		.ai-title {
			font-size: 1.25rem;
		}
	}
</style>
