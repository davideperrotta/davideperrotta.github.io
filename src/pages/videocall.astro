---
import Layout from '../layouts/Layout.astro';
import VideoCallClient from '../components/VideoCallClient.jsx';
---

<Layout>
	<main class="videocall">
		<a href="/" class="videocall__back-button">← Back to site</a>
		<div class="videocall__container">
			<header class="videocall__header">
				<h1>Video Call</h1>
				<p>Connect with others using WebRTC audio and video calling</p>
			</header>			
			<VideoCallClient client:load />
		</div>
	</main>

<style>
	.videocall {
		min-height: 100vh;
		padding: 2rem;
		background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
	}

	.videocall__container {
		max-width: 1200px;
		margin: 0 auto;
	}

	.videocall__header {
		text-align: center;
		margin-bottom: 2rem;
		color: white;
	}

	.videocall__back-button {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		margin-bottom: 1rem;
		margin-left: auto;
		padding: 0.45rem 1rem;
		border-radius: 999px;
		border: none;
		font-size: 0.85rem;
		font-weight: 500;
		text-decoration: none;
		color: #f9fafb;
		background: var(--accent);
		box-shadow: 0 10px 25px rgba(15, 23, 42, 0.6);
		transition: transform 0.12s ease, box-shadow 0.12s ease, background 0.18s ease;
		position: sticky;
		top: 1.25rem;
		z-index: 10;
	}

	.videocall__back-button:hover {
		transform: translateY(-1px);
		box-shadow: 0 14px 32px rgba(15, 23, 42, 0.7);
		background: var(--accent-strong);
	}

	.videocall__header h1 {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 0.5rem;
		background: linear-gradient(135deg, #3b82f6, #8b5cf6);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.videocall__header p {
		font-size: 1.1rem;
		color: #94a3b8;
	}

	@media (max-width: 768px) {
		.videocall {
			padding: 1rem;
		}

		.videocall__header h1 {
			font-size: 2rem;
		}

		.videocall__header p {
			font-size: 1rem;
		}
	}
</style>
