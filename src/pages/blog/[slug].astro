---
import Layout from '../../layouts/Layout.astro';
import { keystaticReader } from '../../keystatic';
import { marked } from 'marked';

interface Props {
	page: {
		slug: string;
		title: string;
		date?: string;
		image?: string | null;
		content?: string;
	};
}

export async function getStaticPaths() {
	const posts = await keystaticReader.collections.blog.all();
	return posts.map((post) => ({ params: { slug: post.slug }, props: { page: { slug: post.slug, ...post.entry } } }));
}

const { page } = Astro.props as Props;

let formattedDate: string | null = null;
if (page.date) {
	const parsed = new Date(page.date);
	if (!Number.isNaN(parsed.getTime())) {
		formattedDate = parsed.toLocaleDateString('en-GB', {
			day: '2-digit',
			month: 'short',
			year: 'numeric',
		});
	}
}

// Remove a leading H1 in the markdown body if it duplicates the page title,
// so we keep a single main H1 for better SEO semantics.
let markdownBody = page.content || '';
const lines = markdownBody.split('\n');
let removedFirstHeading = false;
const filteredLines = [] as string[];

for (const line of lines) {
	if (!removedFirstHeading) {
		const match = line.match(/^#\s+(.+)$/);
		if (match) {
			const headingText = match[1].trim();
			if (headingText === page.title.trim()) {
				removedFirstHeading = true;
				continue;
			}
		}
	}
	filteredLines.push(line);
}

markdownBody = filteredLines.join('\n');
const htmlContent = marked.parse(markdownBody);

const title = `${page.title} · Davide Perrotta`;
const description = page.content?.slice(0, 150) ?? 'Blog post by Davide Perrotta';
---

<Layout {title} {description}>
	<main class="blog-post">
		<a href="/blog" class="blog-post__back button">← Back to blog</a>
		<article class="blog-post__card">
			<header class="blog-post__header">
				<h1 class="blog-post__title">{page.title}</h1>
				{formattedDate && (
					<time class="blog-post__date" datetime={page.date}>{formattedDate}</time>
				)}
				{page.image && (
					<img
						class="blog-post__image"
						src={page.image}
						alt={page.title}
						loading="lazy"
					/>
				)}
			</header>
			<section class="blog-post__content" set:html={htmlContent} />
		</article>
	</main>

<style>
	.blog-post {
		max-width: 1160px;
		margin: 0 auto;
	}

	.blog-post__card {
		background: rgba(15, 23, 42, 0.85);
		border-radius: 1.25rem;
		padding: 1.75rem 1.75rem 2rem;
		border: 1px solid rgba(148, 163, 184, 0.3);
		box-shadow: 0 18px 40px rgba(15, 23, 42, 0.55);
	}

	.blog-post__back.button {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		margin-bottom: 0.9rem;
		margin-left: auto;
		padding: 0.45rem 1rem;
		border-radius: 999px;
		border: none;
		font-size: 0.85rem;
		font-weight: 500;
		text-decoration: none;
		color: #f9fafb;
		background: var(--accent);
		box-shadow: 0 10px 25px rgba(15, 23, 42, 0.6);
		transition: transform 0.12s ease, box-shadow 0.12s ease, background 0.18s ease;
		position: sticky;
		top: 1.25rem;
		z-index: 10;
	}

	.blog-post__back.button:hover {
		transform: translateY(-1px);
		box-shadow: 0 14px 32px rgba(15, 23, 42, 0.7);
		background: var(--accent-strong);
	}

	.blog-post__title {
		margin: 0 0 1rem;
		font-size: 1.8rem;
		letter-spacing: 0.03em;
	}

	.blog-post__date {
		margin-bottom: 0.75rem;
		display: block;
		font-size: 0.9rem;
		color: var(--text-muted);
	}

	.blog-post__image {
		width: 100%;
		height: auto;
		border-radius: 0.9rem;
		margin: 0.5rem 0 1.25rem;
		border: 1px solid rgba(148, 163, 184, 0.4);
	}

	.blog-post__content {
		font-size: 1rem;
		line-height: 1.7;
	}

	.blog-post__content h2,
	.blog-post__content h3,
	.blog-post__content h4 {
		margin-top: 1.6rem;
		margin-bottom: 0.6rem;
	}

	.blog-post__content p {
		margin: 0.6rem 0;
	}

	.blog-post__content ul,
	.blog-post__content ol {
		margin: 0.6rem 0 0.6rem 1.5rem;
	}

	.blog-post__content a {
		color: var(--accent-soft);
		text-decoration: underline;
		text-decoration-thickness: 1px;
	}

	.blog-post__content strong {
		font-weight: 600;
	}

	@media (max-width: 640px) {
		.blog-post__card {
			padding: 1.25rem 1.25rem 1.6rem;
		}

		.blog-post__title {
			font-size: 1.5rem;
		}
	}
</style>

</Layout>
