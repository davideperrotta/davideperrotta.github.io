---
import Layout from '../../layouts/Layout.astro';
import { keystaticReader } from '../../keystatic';
import { marked } from 'marked';

const posts = await keystaticReader.collections.blog.all();
const orderedPosts = posts.toSorted((a, b) => a.slug.localeCompare(b.slug));

const blogPosts = orderedPosts.filter(
	(post) => post.entry.category === 'blog' || post.entry.category === undefined,
);
const seoPosts = orderedPosts.filter((post) => post.entry.category === 'seo');

const title = 'Blog · Davide Perrotta';
const description = 'Articles and notes by Davide Perrotta.';

function getExcerptHtml(markdown?: string) {
	if (!markdown) return '';
	const lines = markdown.split('\n');
	let removedHeading = false;
	const filtered: string[] = [];

	for (const line of lines) {
		if (!removedHeading) {
			if (/^#{1,6}\s+/.test(line)) {
				removedHeading = true;
				continue;
			}
		}
		filtered.push(line);
	}

	const body = filtered.join('\n');
	const firstBlock = (body.split(/\n\n+/)[0] || '').slice(0, 220);
	return marked.parse(firstBlock);
}
---

<Layout {title} {description}>
	<main class="blog-index">
		<section class="blog-index__card">
			<header class="blog-index__header">
				<h1 class="blog-index__title">Blog</h1>
				<a href="/" class="blog-index__back button">← Back to site</a>
			</header>
			{blogPosts.length === 0 && seoPosts.length === 0 ? (
				<p class="blog-index__empty">No posts published yet.</p>
			) : (
				<>
					{blogPosts.length > 0 && (
						<ul class="blog-index__list">
							{blogPosts.map((post) => (
								<li class="blog-index__item">
									<a href={`/blog/${post.slug}`} class="blog-index__link">
										<span class="blog-index__item-title">{post.entry.title}</span>
										{post.entry.content && (
											<span
												class="blog-index__item-excerpt"
												set:html={getExcerptHtml(post.entry.content)}
											/>
										)}
									</a>
								</li>
							))}
						</ul>
					)}

					{seoPosts.length > 0 && (
						<details class="blog-index__seo" role="group">
							<summary class="blog-index__seo-summary">SEO posts</summary>
							<ul class="blog-index__list blog-index__list--seo">
								{seoPosts.map((post) => (
									<li class="blog-index__item">
										<a href={`/blog/${post.slug}`} class="blog-index__link">
											<span class="blog-index__item-title">{post.entry.title}</span>
											{post.entry.content && (
												<span
													class="blog-index__item-excerpt"
													set:html={getExcerptHtml(post.entry.content)}
												/>
											)}
										</a>
									</li>
								))}
							</ul>
						</details>
					)}
				</>
			)}
		</section>
	</main>

<style>
	.blog-index {
		max-width: 720px;
		margin: 0 auto;
	}

	.blog-index__card {
		background: rgba(15, 23, 42, 0.85);
		border-radius: 1.25rem;
		padding: 1.75rem 1.75rem 2rem;
		border: 1px solid rgba(148, 163, 184, 0.3);
		box-shadow: 0 18px 40px rgba(15, 23, 42, 0.55);
	}

	.blog-index__header {
		margin-bottom: 1.25rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
	}

	.blog-index__title {
		margin: 0;
		font-size: 1.8rem;
		letter-spacing: 0.03em;
	}

	.blog-index__back.button {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.45rem 1rem;
		border-radius: 999px;
		border: none;
		font-size: 0.85rem;
		font-weight: 500;
		text-decoration: none;
		color: #f9fafb;
		background: var(--accent);
		box-shadow: 0 10px 25px rgba(15, 23, 42, 0.6);
		transition: transform 0.12s ease, box-shadow 0.12s ease, background 0.18s ease;
	}

	.blog-index__back.button:hover {
		transform: translateY(-1px);
		box-shadow: 0 14px 32px rgba(15, 23, 42, 0.7);
		background: var(--accent-strong);
	}

	.blog-index__empty {
		margin: 0.5rem 0;
		color: var(--text-muted);
	}

	.blog-index__list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.blog-index__item {
		margin: 0;
	}

	.blog-index__link {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		padding: 0.75rem 0.5rem;
		border-radius: 0.75rem;
		text-decoration: none;
		color: inherit;
		transition: background-color 0.15s ease, transform 0.12s ease;
	}

	.blog-index__link:hover {
		background-color: rgba(15, 23, 42, 0.9);
		transform: translateY(-1px);
	}

	.blog-index__item-title {
		font-weight: 600;
	}

	.blog-index__item-excerpt {
		font-size: 0.9rem;
		color: var(--text-muted);
	}

	.blog-index__seo {
		margin-top: 1.75rem;
	}

	.blog-index__seo-summary {
		cursor: pointer;
		font-size: 0.9rem;
		color: var(--accent-soft);
		list-style: none;
	}

	.blog-index__seo[open] .blog-index__seo-summary {
		color: #e5e7eb;
	}

	.blog-index__list--seo {
		margin-top: 0.75rem;
	}

	@media (max-width: 640px) {
		.blog-index__card {
			padding: 1.25rem 1.25rem 1.6rem;
		}

		.blog-index__title {
			font-size: 1.5rem;
		}
	}
</style>

</Layout>
