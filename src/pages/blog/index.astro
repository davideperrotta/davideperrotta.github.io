---
import Layout from '../../layouts/Layout.astro';
import { keystaticReader } from '../../keystatic';
import { marked } from 'marked';

const posts = await keystaticReader.collections.blog.all();
const orderedPosts = posts.toSorted((a, b) => a.slug.localeCompare(b.slug));

const title = 'Blog · Davide Perrotta';
const description = 'Articles and notes by Davide Perrotta.';
---

<Layout {title} {description}>
	<main class="blog-index">
		<section class="blog-index__card">
			<h1 class="blog-index__title">Blog</h1>
			{orderedPosts.length === 0 ? (
				<p class="blog-index__empty">No posts published yet.</p>
			) : (
				<ul class="blog-index__list">
					{orderedPosts.map((post) => (
						<li class="blog-index__item">
							<a href={`/blog/${post.slug}`} class="blog-index__link">
								<span class="blog-index__item-title">{post.entry.title}</span>
								{post.entry.content && (
									<span
										class="blog-index__item-excerpt"
										set:html={marked.parse(
											(post.entry.content.split(/\n\n+/)[0] || '').slice(0, 200),
										)}
									/>
								)}
							</a>
						</li>
					))}
				</ul>
			)}
		</section>
	</main>

<style>
	.blog-index {
		max-width: 720px;
		margin: 0 auto;
	}

	.blog-index__card {
		background: rgba(15, 23, 42, 0.85);
		border-radius: 1.25rem;
		padding: 1.75rem 1.75rem 2rem;
		border: 1px solid rgba(148, 163, 184, 0.3);
		box-shadow: 0 18px 40px rgba(15, 23, 42, 0.55);
	}

	.blog-index__title {
		margin: 0 0 1.25rem;
		font-size: 1.8rem;
		letter-spacing: 0.03em;
	}

	.blog-index__empty {
		margin: 0.5rem 0;
		color: var(--text-muted);
	}

	.blog-index__list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.blog-index__item {
		margin: 0;
	}

	.blog-index__link {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		padding: 0.75rem 0.5rem;
		border-radius: 0.75rem;
		text-decoration: none;
		color: inherit;
		transition: background-color 0.15s ease, transform 0.12s ease;
	}

	.blog-index__link:hover {
		background-color: rgba(15, 23, 42, 0.9);
		transform: translateY(-1px);
	}

	.blog-index__item-title {
		font-weight: 600;
	}

	.blog-index__item-excerpt {
		font-size: 0.9rem;
		color: var(--text-muted);
	}

	@media (max-width: 640px) {
		.blog-index__card {
			padding: 1.25rem 1.25rem 1.6rem;
		}

		.blog-index__title {
			font-size: 1.5rem;
		}
	}
</style>

</Layout>
